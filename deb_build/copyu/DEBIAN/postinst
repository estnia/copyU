#!/bin/bash
set -e

WHEELS_DIR="/opt/copyu/wheels"

echo "正在配置 copyU..."

# 从本地 wheels 安装依赖（先装 evdev，再装 pynput）
if ! python3 -c "import pynput" 2>/dev/null; then
    echo "正在安装 copyU Python 依赖..."
    pip3 install --no-index --find-links="$WHEELS_DIR" evdev pynput
fi

# 更新桌面数据库
update-desktop-database /usr/share/applications/ 2>/dev/null || true

echo "copyU 安装完成"
